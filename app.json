{
  "expo": {
    "name": "Claude Code Remote",
    "slug": "claude-code-remote-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "claude-code-remote",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gldc.claudecoderemote",
      "icon": "./assets/ccr.icon",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#C4613C"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#cb7b5e",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2b217786-e650-43c4-bf18-a36f9ce1aa97"
      }
    },
    "owner": "gldcio",
    "android": {
      "package": "com.gldc.claudecoderemote",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#cb7b5e"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/2b217786-e650-43c4-bf18-a36f9ce1aa97",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    }
  }
}
